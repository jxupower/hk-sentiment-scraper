# ============================================================
# Stock Sentiment Analyzer — Environment Variables
# Copy this file to .env and fill in your credentials.
# ============================================================

# --- Reddit API (optional — free) ---
# Get these at: https://www.reddit.com/prefs/apps
# Click "Create App" → select "script"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SentimentScraper/1.0

# --- Claude AI (optional — improves sentiment accuracy) ---
# Get your key at: https://console.anthropic.com
CLAUDE_API_KEY=

# --- Scraper Settings (optional overrides) ---
SCRAPE_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_SOURCE=50
SENTIMENT_HISTORY_DAYS=90

# --- Dashboard Settings (optional) ---
DASHBOARD_PORT=8050
DASHBOARD_DEBUG=false
