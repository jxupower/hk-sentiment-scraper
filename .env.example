# Copy this file to .env and fill in values you have. All keys are optional —
# the app degrades gracefully when a key is missing.

# ------------------ Optional API credentials ------------------

# Reddit (for r/HKstocks etc. scraper). Without these the Reddit source is
# silently skipped.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SentimentScraper/1.0

# Claude AI (for sentiment scoring + AI sector/business summaries + devil's
# advocate). VADER is used as fallback when this is missing.
CLAUDE_API_KEY=

# ------------------ Dashboard ------------------

DASHBOARD_PORT=8050
DASHBOARD_DEBUG=false

# ------------------ Scraping cadence ------------------

SCRAPE_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_SOURCE=50
SENTIMENT_HISTORY_DAYS=90

# ------------------ Supabase (cloud DB for prices + fundamentals) ------------------

# Toggle: when "true", historical_prices + fundamentals_snapshots reads/writes
# go to Supabase Postgres. When "false" or unset, falls back to local SQLite.
USE_CLOUD_DB=false

# Direct Postgres connection string from your Supabase project:
#   Project Settings → Database → "Connection string" → URI
# Example: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# The 'service_role' key is NOT needed for direct Postgres access — only when
# using the supabase-py SDK. We use psycopg2 directly so just need this URI.
SUPABASE_DB_URL=
